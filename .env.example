# ============================================================================
# BizTrix CRM v2.0 - Nixpacks Environment Configuration TEMPLATE
# ============================================================================
# Copy these variables into Coolify dashboard → Environment Variables
# Works with Nixpacks build system (no Docker needed)
# ============================================================================

# Supabase URLs (Mark as: BUILDTIME + RUNTIME ✅)
VITE_SUPABASE_URL=https://tdqljwenzuptupjihsvg.supabase.co

# Supabase Anon Key - for frontend auth (Mark as: BUILDTIME + RUNTIME ✅)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key - KEEP SECRET! (Mark as: RUNTIME ONLY ✅)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API URL - Using relative path for Nixpacks (Mark as: BUILDTIME + RUNTIME ✅)
# Both frontend and backend served from same origin
VITE_API_URL=/api

# CORS Origin (Mark as: RUNTIME ONLY ✅)
CORS_ORIGIN=*

# Backend port (Mark as: RUNTIME ONLY ✅)
PORT=3001

# ============================================================================
# COOLIFY SETUP INSTRUCTIONS (Nixpacks):
# ============================================================================
#
# Step 1: In Coolify → Your Resource → Settings
#         - Build Pack: Select "Nixpacks"
#         - Remove any Docker Compose file reference
#
# Step 2: Add environment variables with correct flags:
#
#         BUILDTIME + RUNTIME (check both):
#         ✓ VITE_SUPABASE_URL
#         ✓ VITE_SUPABASE_ANON_KEY
#         ✓ VITE_API_URL
#
#         RUNTIME ONLY:
#         ✓ SUPABASE_SERVICE_ROLE_KEY
#         ✓ CORS_ORIGIN
#         ✓ PORT
#
# Step 3: Click "Force Deploy"
#
# Step 4: Nixpacks will:
#         1. Detect Node.js projects in /backend and /frontend
#         2. Build backend (npm install)
#         3. Build frontend (npm install && npm run build)
#         4. Copy frontend dist/ to serve from backend
#         5. Start backend server on PORT 3001
#         6. Serve frontend SPA from same origin
#
# Step 5: Verify:
#         GET https://tokocrypto.live/             → Shows login page
#         GET https://tokocrypto.live/api/health   → Returns API response
#
# ============================================================================
