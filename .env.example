# ============================================================================
# BizTrix CRM v2.0 — Environment Configuration TEMPLATE
# ============================================================================
# Placeholder values ONLY. Never commit real secrets here.
# Set real values in .env (gitignored) locally, or in Coolify service env vars.
# ============================================================================

# Frontend service (Buildtime + Runtime)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=/api

# Backend service (Runtime)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CORS_ORIGIN=https://your-frontend-domain.com
PORT=3001

# Direct Postgres connection (migrations / EXPLAIN tooling)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres
DATABASE_USER=your-db-user@example.com
DATABASE_PASSWORD=your-db-password

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Compliance recording-review cutover. OFF (default/unset) → client portal
# live-resolves recordings as before. Set to true only after the compliance
# admin UI is ready: unconfirmed sales then show "being verified" until a
# compliance manager confirms which recording(s) each sale should play.
RECORDING_REVIEW_GATE_ENABLED=false
